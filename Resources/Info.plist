<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleExecutable</key>
	<string>Quoin</string>
	<key>CFBundleIdentifier</key>
	<string>com.reza.quoin</string>
	<key>CFBundleName</key>
	<string>Quoin</string>
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<!-- Document types: which files this app opens, and with which NSDocument
	     class. "Text Document" (public.text tree) ranks Alternate so Finder
	     offers us without stealing default-app status; the public.data entry
	     lets a code editor open ANY file, ranked None so we never claim it. -->
	<!-- Amendment 1: quoin://open?file=...&amp;line=... deep links, the
	     lingua franca agents and other editors use to point at a location. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.reza.quoin.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>quoin</string>
			</array>
		</dict>
	</array>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Text Document</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.plain-text</string>
				<string>public.text</string>
				<string>public.source-code</string>
			</array>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>NSDocumentClass</key>
			<string>TextDocument</string>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Any File</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.data</string>
			</array>
			<key>LSHandlerRank</key>
			<string>None</string>
			<key>NSDocumentClass</key>
			<string>TextDocument</string>
		</dict>
	</array>
</dict>
</plist>
